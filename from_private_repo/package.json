    "@danielmoncada/angular-datetime-picker": "~20.0.0",
    "@graphql-codegen/typescript-apollo-angular": "~3.5.6",
    "@ng-idle/core": "~13.0.1",
    "@ng-idle/keepalive": "~13.0.0",
    "@swimlane/ngx-charts": "~23.1.0",
