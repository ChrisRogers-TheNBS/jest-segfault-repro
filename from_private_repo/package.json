{
  "name": "manufacturer-platform-internal",
  "version": "0.0.0",
  "scripts": {
    "preinstall": "git config url.\"https://\".insteadOf \"git://\"",
    "ng": "ng",
    "start": "ng serve",
    "start-ie": "ng serve --live-reload=false --configuration es5",
    "start-no": "ng serve --live-reload=false --configuration no",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:localize": "ng build --configuration production --localize",
    "test": "jest",
    "test:no-cache": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "npx eslint",
    "lint-fix": "npx eslint --fix",
    "e2e": "ng e2e",
    "stylelint": "stylelint \"./src/**/*.scss\"",
    "stylelint-fix": "stylelint \"./src/**/*.scss\" --fix",
    "add-schematics": "(cd nbs-source-schematics && npm install)",
    "install-apollo-codegen-deps": "npm install -g apollo apollo-codegen graphql",
    "download-catalogue-gql-schema": "apollo client:download-schema --config=src/apollo.config.js catalogueSchema.json",
    "update-catalogue-queries": "apollo-codegen generate src/app/graphql/*.ts --schema catalogueSchema.json --target typescript --output src/app/graphql/productCatalogueQueries.ts --addTypename",
    "i18n": "ng extract-i18n"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~20.3.18",
    "@angular/cdk": "~20.2.14",
